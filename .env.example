# ─── PostgreSQL (Neon) ───────────────────────────────────────────────────────
# 使用 Neon 的 Pooler 连接串（无服务器环境必须使用 pooler 端点）
DATABASE_URL=postgres://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require

# ─── Upstash Redis ───────────────────────────────────────────────────────────
# 用于存储用户 Session（有状态认证）
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-token>

# ─── Session 密钥 ────────────────────────────────────────────────────────────
# 用于 Session Token 生成（任意随机字符串，至少 32 位）
JWT_SECRET=<random-string-at-least-32-chars>

# ─── 火山云 TOS 对象存储 ────────────────────────────────────────────────────
TOS_ACCESS_KEY_ID=<your-access-key-id>
TOS_ACCESS_KEY_SECRET=<your-access-key-secret>
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_REGION=cn-beijing
BUCKET_NAME=<your-bucket-name>

# ─── 图片 CDN 地址 ───────────────────────────────────────────────────────────
# 末尾带斜杠，例如：https://cdn.example.com/
CDNBASEURL=https://<your-cdn-domain>/
